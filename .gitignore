# ═══════════════════════════════════════════════
# EduNex .gitignore — Security Hardened
# ═══════════════════════════════════════════════

# ─── Secrets & Private Files ──────────────────
PRIVATE/
.env
.env.local
.env.*.local
.env.production
.env.staging
.secure_keys.md

# ─── Internal Docs (private) ──────────────────
.MD/

# ─── Critical App Files (app won't run without) ──
# These files are required to build/run the app.
# Without them, cloning this repo produces broken code.
vite.config.ts
index.html
src/lib/supabase.ts
src/context/AuthContext.tsx
ExWeb/

# ─── Database & SQL (prevent schema leaks) ────
*.sql
supabase/schema.sql
supabase/setup.sql
supabase/migrations/*.sql

# ─── Supabase Local ───────────────────────────
supabase/.temp/

# ─── Logs ─────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Lint & Test Results ──────────────────────
.eslintcache
eslint-report.*
lint-results.*
coverage/
*.lcov
.nyc_output/

# ─── Dependencies ─────────────────────────────
node_modules

# ─── Build Output ─────────────────────────────
dist
dist-ssr
*.local

# ─── Editor Config ────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Design / Reference Files ─────────────────
ExWeb/

# ─── Misc Temp Files ──────────────────────────
last.md
final_lint.txt
final_lint_json.txt
lint_results.txt
